<!DOCTYPE html>
<html lang="{{ .Language.Lang }}">
<head>
    <meta charset="UTF-8">
    <title>{{ .Title }}</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header style="display: flex; justify-content: space-between; align-items: center; padding: 20px; border-bottom: 2px solid #eee;">
        <div class="logo"><strong>Congo Enterprise Hub</strong></div>
        
        <nav>
            <ul style="display: flex; list-style: none; gap: 20px; align-items: center;">
                {{ range index .Site.Menus .Language.Lang }}
                    <li><a href="{{ .URL }}">{{ .Name }}</a></li>
                {{ end }}
                
                <li style="margin-left: 30px; padding-left: 20px; border-left: 2px solid #ccc;">
                    <div class="language-switcher">
                        🌍 
                        {{ range .AllTranslations }}
                            <a href="{{ .RelPermalink }}" style="margin-right: 10px;">
                                {{ .Language.LanguageName }}
                            </a>
                        {{ end }}
                    </div>
                </li>
            </ul>
        </nav>
    </header>

    <main>
        {{ block "main" . }}{{ end }}
    </main>
</body>
</html>
